# ──────────────────────────────────────────
# Burger Empire — Environment Variables
# Copy this file to .env and fill in values
# ──────────────────────────────────────────

# Database (PostgreSQL via Neon)
# These are auto-injected by the Neon integration on Vercel.
# For local dev, set both to the same URL.
POSTGRES_PRISMA_URL="postgresql://user:password@localhost:5432/burgerempire"
POSTGRES_URL_NON_POOLING="postgresql://user:password@localhost:5432/burgerempire"

# PetPooja POS Integration
# Get these from your PetPooja dashboard
PETPOOJA_API_URL="https://qle1yy2ydc.execute-api.ap-southeast-1.amazonaws.com/V1"
PETPOOJA_ORDER_API_URL="https://47pfzh5sf2.execute-api.ap-southeast-1.amazonaws.com/V1"
PETPOOJA_APP_KEY=""
PETPOOJA_APP_SECRET=""
PETPOOJA_ACCESS_TOKEN=""
PETPOOJA_RESTAURANT_ID=""
PETPOOJA_WEBHOOK_TOKEN=""

# Authentication (CHANGE THESE IN PRODUCTION!)
JWT_SECRET="change-this-to-a-random-secret-in-production"
JWT_REFRESH_SECRET="change-this-to-another-random-secret-in-production"

# App URL
NEXT_PUBLIC_APP_URL="http://localhost:7001"

# Razorpay Payment Gateway (optional — COD works without this)
RAZORPAY_KEY_ID=""
RAZORPAY_KEY_SECRET=""
NEXT_PUBLIC_RAZORPAY_KEY_ID=""

# Email (Nodemailer / SMTP — optional)
SMTP_HOST=""
SMTP_PORT="587"
SMTP_USER=""
SMTP_PASS=""
SMTP_FROM="Burger Empire <hello@build.withdarsh.com>"

# SMS / OTP (optional — uses console log in dev if not set)
SMS_PROVIDER=""
SMS_API_KEY=""
SMS_SENDER_ID="BRGEMP"

# Google Analytics (optional)
NEXT_PUBLIC_GA_MEASUREMENT_ID=""

# Cloudinary (Image Uploads)
CLOUDINARY_CLOUD_NAME=""
CLOUDINARY_API_KEY=""
CLOUDINARY_API_SECRET=""
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=""

# Coming Soon / Preview mode
# "true" = countdown landing page (production), "false" = full site visible (dev)
NEXT_PUBLIC_COMING_SOON="true"

# Preview mode (generate token URLs so others can preview while site is in coming-soon)
PREVIEW_SECRET=""

# Cron job secret (for scheduled tasks)
CRON_SECRET=""
